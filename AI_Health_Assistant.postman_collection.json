{
  "info": {
    "name": "AI Health Assistant API",
    "description": "Complete API collection for the AI Health Assistant backend.\n\nSETUP:\n1. Set {{baseUrl}} = http://localhost:5001\n2. Run 'Register' or 'Login' first — token is auto-saved\n3. All protected routes use {{authToken}} automatically\n\nAUTH FLOW:\nRegister → Login → (token saved) → use any protected endpoint",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",   "value": "http://localhost:5001", "type": "string" },
    { "key": "authToken", "value": "",                      "type": "string" },
    { "key": "reminderId",    "value": "", "type": "string" },
    { "key": "appointmentId", "value": "", "type": "string" },
    { "key": "readingId",     "value": "", "type": "string" },
    { "key": "contactId",     "value": "", "type": "string" },
    { "key": "reportId",      "value": "", "type": "string" },
    { "key": "sessionId",     "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "00 — Health Check",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "description": "Public. Verifies the server is running. Used by Docker and AWS App Runner healthchecks."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('success true', () => pm.expect(pm.response.json().success).to.be.true);",
            "pm.test('Has timestamp', () => pm.expect(pm.response.json().timestamp).to.exist);"
          ]}}]
        }
      ]
    },

    {
      "name": "01 — Authentication",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPass1\"\n}"
            },
            "description": "Creates a new user. Returns JWT token in data.token."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Has token', () => { const r=pm.response.json(); pm.expect(r.data.token).to.exist; pm.collectionVariables.set('authToken', r.data.token); });",
            "pm.test('Has user object', () => pm.expect(pm.response.json().data.user).to.exist);",
            "pm.test('No password in response', () => pm.expect(pm.response.json().data.user.password).to.be.undefined);"
          ]}}]
        },
        {
          "name": "POST /api/auth/login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPass1\"\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Token saved', () => { const t=pm.response.json().data.token; pm.collectionVariables.set('authToken',t); pm.expect(t).to.exist; });"
          ]}}]
        },
        {
          "name": "POST /api/auth/login — Wrong Password (expect 401)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"WrongPassword\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));",
            "pm.test('Generic message (no email enumeration)', () => pm.expect(pm.response.json().message).to.include('Invalid'));"
          ]}}]
        },
        {
          "name": "POST /api/auth/register — Validation fail (expect 422)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"A\",\n  \"email\": \"not-an-email\",\n  \"password\": \"short\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 422', () => pm.response.to.have.status(422));",
            "pm.test('Has errors array', () => pm.expect(pm.response.json().errors).to.be.an('array'));"
          ]}}]
        },
        {
          "name": "GET /api/auth/me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('User object returned', () => pm.expect(pm.response.json().data.user).to.exist);",
            "pm.test('No password field', () => pm.expect(pm.response.json().data.user.password).to.be.undefined);"
          ]}}]
        },
        {
          "name": "GET /api/auth/me — No token (expect 401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401 without token', () => pm.response.to.have.status(401));"
          ]}}]
        },
        {
          "name": "POST /api/auth/logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}]
        }
      ]
    },

    {
      "name": "02 — Symptom Checker",
      "item": [
        {
          "name": "POST /api/symptoms/analyze — New session",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/symptoms/analyze",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"message\": \"I have had a persistent headache and mild fever for 2 days\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const d = pm.response.json().data;",
            "pm.test('Has sessionId', () => { pm.expect(d.sessionId).to.exist; pm.collectionVariables.set('sessionId', d.sessionId); });",
            "pm.test('isNewSession true', () => pm.expect(d.isNewSession).to.be.true);",
            "pm.test('Has response', () => pm.expect(d.response).to.be.a('string').with.lengthOf.above(10));",
            "pm.test('Has messageCount', () => pm.expect(d.messageCount).to.equal(2));"
          ]}}]
        },
        {
          "name": "POST /api/symptoms/analyze — Continue session",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/symptoms/analyze",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"message\": \"The headache is mostly on the left side, throbbing\",\n  \"sessionId\": \"{{sessionId}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('isNewSession false (continued)', () => pm.expect(pm.response.json().data.isNewSession).to.be.false);",
            "pm.test('messageCount increased to 4', () => pm.expect(pm.response.json().data.messageCount).to.equal(4));"
          ]}}]
        },
        {
          "name": "POST /api/symptoms/analyze — Empty message (expect 422)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/symptoms/analyze",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"message\": \"\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 422 on empty message', () => pm.response.to.have.status(422));"
          ]}}]
        },
        {
          "name": "GET /api/symptoms/sessions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/symptoms/sessions",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has sessions array', () => pm.expect(pm.response.json().data.sessions).to.be.an('array'));",
            "pm.test('Has count', () => pm.expect(pm.response.json().data.count).to.be.a('number'));"
          ]}}]
        },
        {
          "name": "GET /api/symptoms/sessions/:sessionId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/symptoms/sessions/{{sessionId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has messages array', () => pm.expect(pm.response.json().data.session.messages).to.be.an('array'));"
          ]}}]
        }
      ]
    },

