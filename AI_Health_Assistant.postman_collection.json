    {
      "name": "04 — Medical Reports",
      "item": [
        {
          "name": "POST /api/reports/upload",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/reports/upload",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "report", "type": "file", "src": "/path/to/medical_report.pdf", "description": "Replace with actual PDF path" }]
            },
            "description": "Content-Type: multipart/form-data. Field name must be 'report'. Max 5MB PDF only."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const r = pm.response.json().data.report;",
            "pm.test('Has _id', () => { pm.expect(r._id).to.exist; pm.collectionVariables.set('reportId', r._id); });",
            "pm.test('Has aiSummary', () => pm.expect(r.aiSummary).to.be.a('string'));",
            "pm.test('Has keyFindings array', () => pm.expect(r.keyFindings).to.be.an('array'));",
            "pm.test('Has urgencyLevel', () => pm.expect(['low','medium','high']).to.include(r.urgencyLevel));",
            "pm.test('No binary PDF stored', () => pm.expect(r.fileBuffer).to.be.undefined);"
          ]}}]
        },
        {
          "name": "POST /api/reports/upload — Wrong field name (expect 400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/reports/upload",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "/path/to/report.pdf", "description": "Wrong field name — should be 'report'" }]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400 — wrong field name', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "GET /api/reports",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reports",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has reports array', () => pm.expect(pm.response.json().data.reports).to.be.an('array'));",
            "pm.test('extractedText excluded from list', () => { const r=pm.response.json().data.reports; if(r.length>0) pm.expect(r[0].extractedText).to.be.undefined; });"
          ]}}]
        },
        {
          "name": "GET /api/reports/:id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reports/{{reportId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has extractedText (full view)', () => pm.expect(pm.response.json().data.report.extractedText).to.exist);"
          ]}}]
        },
        {
          "name": "GET /api/reports/:id — Invalid ID (expect 400)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reports/not-a-real-id",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
